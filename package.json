{
  "name": "package-age",
  "version": "0.4.1",
  "description": "A CLI for detecting old dependencies used in your project",
  "type": "module",
  "exports": "./index.js",
  "bin": {
    "package-age": "./cli.js"
  },
  "files": [
    "lib/",
    "cli.js",
    "index.js"
  ],
  "scripts": {
    "lint": "eslint **/*.js",
    "mocha": "c8 mocha",
    "test": "npm run lint && npm run mocha",
    "coverage": "c8 report --reporter=text-lcov > coverage/lcov.info"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "read-pkg": "^10.1.0",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "mocha": "^11.7.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ENT8R/package-age.git"
  },
  "keywords": [
    "package",
    "npm",
    "age",
    "old",
    "unsupported",
    "dependencies",
    "dependency",
    "cli"
  ],
  "author": "ENT8R",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/ENT8R/package-age/issues"
  },
  "homepage": "https://github.com/ENT8R/package-age"
}
